{
  "name": "automation-cypress",
  "version": "1.0.0",
  "description": "Automation with Cypress to demonstrate my skills with the tool.",
  "main": "index.js",
  "scripts": {
    "cy:open": "cypress open",
    "cy:run": "cypress run",
    "cy:run:chrome": "cypress run --browser chrome",
    "cy:run:headed": "cypress run --headed --browser chrome",

    "test": "cypress run",
    "test:ui": "cypress run --spec 'cypress/e2e/**/*.cy.js' --ignore 'cypress/e2e/api/**/*.cy.js'",
    "test:api": "cypress run --spec 'cypress/e2e/api/**/*.cy.js'",
    "test:all": "cypress run"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "cypress": "^15.18.0",
    "typescript": "^6.0.3"
  }
}
