{
  "name": "automation-cypress",
  "version": "1.0.0",
  "description": "Automation with Cypress to demonstrate my skills with the tool.",
  "main": "index.js",
  "scripts": {
    "cy:open": "cypress open",
    "cy:run": "cypress run",
    "cy:run:chrome": "cypress run --browser chrome",
    "test": "cypress run",
    "test:ui": "cypress run --spec 'cypress/e2e/**/*.feature'",
    "test:api": "cypress run --spec 'cypress/e2e/api/**/*.cy.js'",
    "test:all": "cypress run",
    "test:report": "cypress run --reporter cypress-mochawesome-reporter",
    "test:parallel": "cypress run --record --parallel --browser chrome"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@badeball/cypress-cucumber-preprocessor": "^26.0.0",
    "@bahmutov/cypress-esbuild-preprocessor": "^2.2.8",
    "@faker-js/faker": "^10.5.0",
    "cross-env": "^10.1.0",
    "cypress": "^15.18.0",
    "cypress-mochawesome-reporter": "^4.0.2",
    "dotenv": "^17.4.2"
  }
}
